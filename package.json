{
  "name": "rta-aid-backend",
  "version": "1.0.0",
  "description": "Relief Track Aid Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "npx prisma generate && node src/app.js",
    "dev": "nodemon src/app.js",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:reset": "npx prisma db push --force-reset && npx prisma db seed",
    "prisma:pull": "npx prisma db pull",
    "prisma:generate": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-list-endpoints": "^7.1.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0"
  }
}
