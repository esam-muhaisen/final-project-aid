generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model aid_categories {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(80)
  description String?     @db.Text
  aid_types   aid_types[]
}

model aid_types {
  id                 Int                  @id @default(autoincrement())
  category_id        Int
  name               String               @db.VarChar(120)
  unit               String?              @default("item") @db.VarChar(30)
  aid_categories     aid_categories       @relation(fields: [category_id], references: [id], onUpdate: Restrict, map: "aid_types_ibfk_1")
  aids               aids[]
  beneficiary_orders beneficiary_orders[]
  beneficiary_aids   beneficiary_aids[]

  @@index([category_id], map: "category_id")
}

model aids {
  id                  Int                  @id @default(autoincrement())
  aid_type_id         Int
  org_id              Int?
  quantity            Int
  remaining_quantity  Int
  status              aids_status?         @default(active)
  batch_code          String?              @unique(map: "batch_code") @db.VarChar(50)
  created_at          DateTime             @default(now()) @db.Timestamp(0)
  aid_types           aid_types            @relation(fields: [aid_type_id], references: [id], onUpdate: Restrict, map: "aids_ibfk_1")
  local_organizations local_organizations? @relation(fields: [org_id], references: [id], onUpdate: Restrict, map: "aids_ibfk_2")


  @@index([aid_type_id], map: "aid_type_id")
  @@index([org_id], map: "org_id")
}

model areas {
  id                  Int                   @id @default(autoincrement())
  governorate_id      Int
  name                String                @db.VarChar(100)
  governorates        governorates          @relation(fields: [governorate_id], references: [id], onUpdate: Restrict, map: "areas_ibfk_1")
  beneficiaries       beneficiaries[]
  local_organizations local_organizations[]
  pickup_locations    pickup_locations[]

  @@index([governorate_id], map: "governorate_id")
}

model pickup_locations {
  id               Int                @id @default(autoincrement())
  area_id          Int
  name             String             @db.VarChar(200)
  areas            areas              @relation(fields: [area_id], references: [id], onUpdate: Restrict, map: "pickup_locations_ibfk_1")
  beneficiary_aids beneficiary_aids[]

  @@index([area_id], map: "area_id")
}

model beneficiary_orders {
  id               Int                        @id @default(autoincrement())
  beneficiary_id   Int
  aid_type_id      Int
  description      String?                    @db.Text
  status           beneficiary_orders_status? @default(pending)
  created_at       DateTime                   @default(now()) @db.Timestamp(0)
  beneficiaries    beneficiaries              @relation(fields: [beneficiary_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "beneficiary_orders_ibfk_1")
  aid_types        aid_types                  @relation(fields: [aid_type_id], references: [id], onUpdate: Restrict, map: "beneficiary_orders_ibfk_2")
  beneficiary_aids beneficiary_aids?

  @@index([beneficiary_id], map: "beneficiary_id")
  @@index([aid_type_id], map: "aid_type_id")
}

model audit_logs {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String   @db.VarChar(100)
  table_name String?  @db.VarChar(60)
  record_id  Int?
  created_at DateTime @default(now()) @db.Timestamp(0)
  users      users?   @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "audit_logs_ibfk_1")

  @@index([user_id], map: "user_id")
}

model beneficiaries {
  id                        Int                         @id @default(autoincrement())
  user_id                   Int                         @unique(map: "user_id")
  national_id               String                      @unique(map: "national_id") @db.VarChar(20)
  area_id                   Int?
  family_size               Int
  income                    Decimal?                    @default(0.00) @db.Decimal(10, 2)
  patients_count            Int?                        @default(0)
  disabled_count            Int?                        @default(0)
  is_displaced              Boolean?                    @default(false)
  release_date              DateTime                    @db.Date
  priority_score            Decimal?                    @default(0.00) @db.Decimal(8, 2)
  status                    beneficiaries_status?       @default(pending)
  created_at                DateTime                    @default(now()) @db.Timestamp(0)
  users                     users                       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "beneficiaries_ibfk_1")
  areas                     areas?                      @relation(fields: [area_id], references: [id], onUpdate: Restrict, map: "beneficiaries_ibfk_2")
  beneficiary_verifications beneficiary_verifications[]
  beneficiary_orders        beneficiary_orders[]
  beneficiary_aids          beneficiary_aids[]
  complaints                complaints[]


  @@index([area_id], map: "area_id")
}

model beneficiary_verifications {
  id                  Int                              @id @default(autoincrement())
  beneficiary_id      Int
  org_id              Int?
  verified_by         Int?
  result              beneficiary_verifications_result
  notes               String?                          @db.Text
  created_at          DateTime                         @default(now()) @db.Timestamp(0)
  beneficiaries       beneficiaries                    @relation(fields: [beneficiary_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "beneficiary_verifications_ibfk_1")
  local_organizations local_organizations?             @relation(fields: [org_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "beneficiary_verifications_ibfk_2")
  users               users?                           @relation(fields: [verified_by], references: [id], onUpdate: Restrict, map: "beneficiary_verifications_ibfk_3")

  @@index([beneficiary_id], map: "beneficiary_id")
  @@index([org_id], map: "org_id")
  @@index([verified_by], map: "verified_by")
}

model campaigns {
  id               Int               @id @default(autoincrement())
  title            String            @db.VarChar(200)
  description      String?           @db.Text
  target_amount    Decimal?          @db.Decimal(12, 2)
  collected_amount Decimal?          @default(0.00) @db.Decimal(12, 2)
  start_date       DateTime?         @db.Date
  end_date         DateTime?         @db.Date
  status           campaigns_status? @default(active)
  created_at       DateTime          @default(now()) @db.Timestamp(0)
}

model complaints {
  id             Int                @id @default(autoincrement())
  beneficiary_id Int
  subject        String             @db.VarChar(200)
  message        String             @db.Text
  status         complaints_status? @default(open)
  admin_response String?            @db.Text
  resolved_by    Int?
  created_at     DateTime           @default(now()) @db.Timestamp(0)
  beneficiaries  beneficiaries      @relation(fields: [beneficiary_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "complaints_ibfk_1")
  users          users?             @relation(fields: [resolved_by], references: [id], onUpdate: Restrict, map: "complaints_ibfk_2")

  @@index([beneficiary_id], map: "beneficiary_id")
  @@index([resolved_by], map: "resolved_by")
}

model donations {
  id            Int                 @id @default(autoincrement())
  guest_name    String?             @db.VarChar(100)
  guest_email   String?             @db.VarChar(150)
  amount        Decimal             @db.Decimal(10, 2)
  currency      String?             @default("ILS") @db.VarChar(10)
  status        donations_status?   @default(completed)
  donated_at    DateTime            @default(now()) @db.Timestamp(0)
}

model governorates {
  id    Int     @id @default(autoincrement())
  name  String  @db.VarChar(80)
  areas areas[]
}

model local_organizations {
  id                        Int                         @id @default(autoincrement())
  user_id                   Int                         @unique(map: "user_id")
  org_name                  String                      @db.VarChar(200)
  area_id                   Int?
  is_verified               Boolean?                    @default(false)
  focus_area                String?                     @db.VarChar(200)
  staff_count               Int?                        @default(0)
  aids                      aids[]

  beneficiary_verifications beneficiary_verifications[]
  users                     users                       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "local_organizations_ibfk_1")
  areas                     areas?                      @relation(fields: [area_id], references: [id], onUpdate: Restrict, map: "local_organizations_ibfk_2")

  @@index([area_id], map: "area_id")
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(200)
  message    String   @db.Text
  is_read    Boolean? @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "notifications_ibfk_1")

  @@index([user_id], map: "user_id")
}

model users {
  id                        Int                         @id @default(autoincrement())
  name                      String                      @db.VarChar(100)
  email                     String?                     @unique(map: "email") @db.VarChar(150)
  password                  String                      @db.VarChar(255)
  role                      users_role
  phone                     String?                     @db.VarChar(20)
  is_active                 Boolean?                    @default(true)
  created_at                DateTime                    @default(now()) @db.Timestamp(0)
  audit_logs                audit_logs[]
  beneficiaries             beneficiaries?
  beneficiary_verifications beneficiary_verifications[]
  complaints                complaints[]
  local_organizations       local_organizations?
  notifications             notifications[]
  beneficiary_aids          beneficiary_aids[]
    sync_logs                 sync_logs[]
}


enum sync_logs_sync_status {
  pending
  synced
  failed
}

model sync_logs {
  id             Int                   @id @default(autoincrement())
  user_id        Int?
  operation_type String                @db.VarChar(50)
  table_name     String                @db.VarChar(100)
  record_id      Int?
  sync_status    sync_logs_sync_status @default(pending)
  created_at     DateTime              @default(now()) @db.Timestamp(0)
  synced_at      DateTime?             @db.Timestamp(0)
  users          users?                @relation(fields: [user_id], references: [id], onDelete: SetNull, map: "sync_logs_ibfk_1")

  @@index([user_id], map: "user_id")
}

enum beneficiary_verifications_result {
  approved
  rejected
}

enum complaints_status {
  open
  under_review
  resolved
}

enum users_role {
  admin
  beneficiary
  local_org
}

enum aids_status {
  active
  exhausted
  expired
}

enum campaigns_status {
  active
  closed
}

enum donations_status {
  pending
  completed
  failed
}

enum beneficiaries_status {
  pending
  eligible
  not_eligible
}

enum beneficiary_orders_status {
  pending
  approved
  rejected
}

model beneficiary_aids {
  id                 Int                     @id @default(autoincrement())
  beneficiary_id     Int
  aid_type_id        Int
  pickup_location_id Int?
  verify_by_user_id  Int
  order_id           Int?                    @unique(map: "beneficiary_aids_order_id_unique")
  status             beneficiary_aids_status
  created_at         DateTime                @default(now()) @db.Timestamp(0)
  updated_at         DateTime                @default(now()) @updatedAt @db.Timestamp(0)

  beneficiaries      beneficiaries       @relation(fields: [beneficiary_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "beneficiary_aids_ibfk_1")
  aid_types          aid_types           @relation(fields: [aid_type_id], references: [id], onUpdate: Restrict, map: "beneficiary_aids_ibfk_2")
  pickup_locations   pickup_locations?   @relation(fields: [pickup_location_id], references: [id], onUpdate: Restrict, map: "beneficiary_aids_ibfk_3")
  users              users               @relation(fields: [verify_by_user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "beneficiary_aids_ibfk_4")
  beneficiary_orders beneficiary_orders? @relation(fields: [order_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "beneficiary_aids_ibfk_5")

  @@index([beneficiary_id], map: "beneficiary_id")
  @@index([aid_type_id], map: "aid_type_id")
  @@index([pickup_location_id], map: "pickup_location_id")
  @@index([verify_by_user_id], map: "user_id")
}


enum beneficiary_aids_status {
  rejected
  approved
  preparing
  shipping
  delivered
}
